<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="40dp"
    android:paddingEnd="24dp"
    android:paddingBottom="180dp"
    tools:showIn="@layout/fragment_onboarding">

    <ImageView
        android:id="@id/onboarding_page_art"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:adjustViewBounds="true"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        tools:src="@drawable/art_onboarding_daily" />

    <TextView
        android:id="@id/onboarding_page_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/noto_serif_tc_family"
        android:gravity="center"
        android:textColor="@color/ic_ink"
        android:textSize="28sp"
        tools:text="每日靜心" />

    <TextView
        android:id="@id/onboarding_page_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/ic_text_muted"
        android:textSize="16sp"
        tools:text="每天用一卦，整理當下的心。" />
</LinearLayout>
