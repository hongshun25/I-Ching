<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@id/hexagram_item_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:padding="@dimen/card_padding"
    tools:showIn="@layout/fragment_learn_center">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <fcu.app.i_ching.ui.HexagramView
            android:id="@id/hexagram_item_hexagram"
            android:layout_width="46dp"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@id/hexagram_item_number"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ic_text_muted"
                android:textSize="12sp"
                tools:text="第15卦" />

            <TextView
                android:id="@id/hexagram_item_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/noto_serif_cjk_tc_regular"
                android:textColor="@color/ic_ink"
                android:textSize="24sp"
                tools:text="地山謙" />

            <TextView
                android:id="@id/hexagram_item_trigrams"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ic_text_muted"
                android:textSize="12sp"
                tools:text="上坤 · 下艮" />
        </LinearLayout>

            <ImageButton
                android:id="@id/hexagram_item_favorite"
                android:layout_width="@dimen/touch_target"
                android:layout_height="@dimen/touch_target"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="加入收藏"
                android:padding="10dp"
                android:scaleType="center"
                android:src="@drawable/ic_favorite_border_24"
                app:tint="@color/favorite_tint" />
    </LinearLayout>

    <TextView
        android:id="@id/hexagram_item_tags"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="@color/ic_text_muted"
        android:textSize="13sp"
        android:textStyle="bold"
        tools:text="謙虛 退讓 平衡 吉卦" />
</LinearLayout>
