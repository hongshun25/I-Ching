<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page"
    android:fillViewport="true"
    tools:context=".ui.AuthFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="64dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/noto_serif_tc_family"
            android:gravity="center"
            android:text="@string/auth_title"
            android:textColor="@color/ic_ink"
            android:textSize="38sp"
            android:textStyle="bold" />

        <TextView
            style="@style/IChingBodyText"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="36dp"
            android:gravity="center"
            android:text="@string/splash_tagline" />

        <LinearLayout
            style="@style/IChingCard"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="22dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@id/auth_login_tab"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/auth_login_tab"
                    android:textColor="@color/ic_ink"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@id/auth_register_tab"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/auth_register_tab"
                    android:textColor="@color/ic_text_muted"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@id/auth_login_form"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/SettingsRowLabel"
                    android:layout_width="match_parent"
                    android:layout_weight="0"
                    android:text="@string/auth_email_label" />

                <EditText
                    android:id="@id/auth_login_email"
                    style="@style/IChingInput"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:hint="@string/auth_email_hint"
                    android:imeOptions="actionNext"
                    android:inputType="textEmailAddress"
                    android:singleLine="true"
                    tools:text="user@example.com" />

                <TextView
                    style="@style/SettingsRowLabel"
                    android:layout_width="match_parent"
                    android:layout_marginTop="16dp"
                    android:layout_weight="0"
                    android:text="@string/auth_password_label" />

                <EditText
                    android:id="@id/auth_login_password"
                    style="@style/IChingInput"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:hint="@string/auth_login_password_hint"
                    android:imeOptions="actionDone"
                    android:inputType="textPassword"
                    android:singleLine="true" />

                <com.google.android.material.button.MaterialButton
                    android:id="@id/auth_login_button"
                    style="@style/IChingPrimaryButton"
                    android:layout_marginTop="24dp"
                    android:text="@string/auth_login" />

                <com.google.android.material.button.MaterialButton
                    android:id="@id/auth_switch_register_button"
                    style="@style/IChingSecondaryButton"
                    android:layout_marginTop="12dp"
                    android:text="@string/auth_switch_register" />
            </LinearLayout>

            <LinearLayout
                android:id="@id/auth_register_form"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/SettingsRowLabel"
                    android:layout_width="match_parent"
                    android:layout_weight="0"
                    android:text="@string/auth_email_label" />

                <EditText
                    android:id="@id/auth_register_email"
                    style="@style/IChingInput"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:hint="@string/auth_email_hint"
                    android:imeOptions="actionNext"
                    android:inputType="textEmailAddress"
                    android:singleLine="true"
                    tools:text="user@example.com" />

                <TextView
                    style="@style/SettingsRowLabel"
                    android:layout_width="match_parent"
                    android:layout_marginTop="16dp"
                    android:layout_weight="0"
                    android:text="@string/auth_password_label" />

                <EditText
                    android:id="@id/auth_register_password"
                    style="@style/IChingInput"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:hint="@string/auth_register_password_hint"
                    android:imeOptions="actionNext"
                    android:inputType="textPassword"
                    android:singleLine="true" />

                <TextView
                    style="@style/SettingsRowLabel"
                    android:layout_width="match_parent"
                    android:layout_marginTop="16dp"
                    android:layout_weight="0"
                    android:text="@string/auth_confirm_label" />

                <EditText
                    android:id="@id/auth_register_confirm"
                    style="@style/IChingInput"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:hint="@string/auth_confirm_hint"
                    android:imeOptions="actionDone"
                    android:inputType="textPassword"
                    android:singleLine="true" />

                <com.google.android.material.button.MaterialButton
                    android:id="@id/auth_register_button"
                    style="@style/IChingPrimaryButton"
                    android:layout_marginTop="24dp"
                    android:text="@string/auth_register" />

                <com.google.android.material.button.MaterialButton
                    android:id="@id/auth_switch_login_button"
                    style="@style/IChingSecondaryButton"
                    android:layout_marginTop="12dp"
                    android:text="@string/auth_switch_login" />
            </LinearLayout>

            <TextView
                android:id="@id/auth_message"
                style="@style/IChingBodyText"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:textColor="@color/ic_error"
                android:visibility="gone"
                tools:text="電子郵件或密碼不正確"
                tools:visibility="visible" />

            <TextView
                style="@style/TextAppearance.IChing.Caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="@string/auth_local_note" />
        </LinearLayout>

        <LinearLayout
            android:id="@id/auth_skip_button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="28dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_cloud_off_24"
                app:tint="@color/ic_text_muted" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auth_skip"
                android:textColor="@color/ic_text_muted"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
