<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ic_background"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@id/ritual_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginStart="24dp"
        android:layout_marginTop="72dp"
        android:layout_marginEnd="24dp"
        android:fontFamily="serif"
        android:gravity="center"
        android:text="@string/ritual_header"
        android:textColor="@color/ic_ink"
        android:textSize="24sp" />

    <ProgressBar
        android:id="@id/ritual_progress"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="148dp"
        android:layout_height="148dp"
        android:layout_gravity="center" />

    <TextView
        android:id="@id/ritual_focus"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="center"
        android:fontFamily="serif"
        android:gravity="center"
        android:text="@string/ritual_focus_symbol"
        android:textColor="@color/ic_gold"
        android:textSize="72sp" />

    <Button
        android:id="@id/ritual_skip_button"
        style="@style/IChingSecondaryButton"
        android:layout_gravity="bottom"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        android:text="@string/ritual_skip" />
</FrameLayout>
