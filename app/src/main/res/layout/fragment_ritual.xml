<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page"
    android:clickable="true"
    android:focusable="true"
    tools:context=".ui.RitualFragment">

    <TextView
        android:id="@id/ritual_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginStart="24dp"
        android:layout_marginTop="72dp"
        android:layout_marginEnd="24dp"
        android:fontFamily="@font/noto_serif_cjk_tc_regular"
        android:gravity="center"
        android:text="@string/ritual_header"
        android:textColor="@color/ic_ink"
        android:textSize="24sp" />

    <fcu.app.i_ching.ui.RitualFocusView
        android:id="@id/ritual_focus"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_gravity="center"
        android:contentDescription="@string/ritual_focus_description" />

    <TextView
        android:id="@id/ritual_skip_button"
        style="@style/IChingSecondaryButton"
        android:layout_gravity="bottom"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        android:text="@string/ritual_skip" />
</FrameLayout>
