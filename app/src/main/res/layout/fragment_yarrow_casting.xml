<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page"
    android:orientation="vertical"
    tools:context=".ui.YarrowCastingFragment">

    <include
        android:id="@id/yarrow_top_bar"
        layout="@layout/include_top_bar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <TextView
                style="@style/IChingPageTitle"
                android:gravity="center"
                android:text="@string/yarrow_title"
                android:textSize="34sp" />

            <TextView
                style="@style/IChingBodyText"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/yarrow_body" />

            <LinearLayout
                style="@style/IChingCard"
                android:layout_marginTop="28dp">

                <TextView
                    android:id="@id/yarrow_step_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/noto_serif_tc_family"
                    android:textColor="@color/ic_ink"
                    android:textSize="24sp"
                    tools:text="第1爻・第1變" />

                <TextView
                    android:id="@id/yarrow_step_body"
                    style="@style/IChingBodyText"
                    android:layout_marginTop="10dp"
                    tools:text="本變取出 5 策，餘 44 策。" />

                <ProgressBar
                    android:id="@id/yarrow_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="20dp"
                    android:max="18"
                    android:progress="0" />
            </LinearLayout>

            <TextView
                android:id="@id/yarrow_line_values"
                style="@style/IChingBodyText"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_card"
                android:padding="@dimen/card_padding"
                tools:text="第1爻 待定&#10;第2爻 待定&#10;第3爻 待定" />

            <com.google.android.material.button.MaterialButton
                android:id="@id/yarrow_next_button"
                style="@style/IChingPrimaryButton"
                android:layout_marginTop="24dp"
                android:drawableEnd="@drawable/ic_arrow_forward_24"
                android:drawablePadding="8dp"
                android:drawableTint="@color/ic_background"
                android:text="@string/yarrow_next" />

            <com.google.android.material.button.MaterialButton
                android:id="@id/yarrow_quick_button"
                style="@style/IChingSecondaryButton"
                android:layout_marginTop="10dp"
                android:text="@string/yarrow_quick" />
        </LinearLayout>
    </ScrollView>

    <include
        android:id="@id/yarrow_bottom_nav"
        layout="@layout/include_bottom_nav" />
</LinearLayout>
