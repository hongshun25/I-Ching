<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page"
    android:fillViewport="true"
    tools:context=".ui.QuestionFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/question_step"
            android:textColor="@color/ic_gold"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            style="@style/IChingPageTitle"
            android:gravity="center"
            android:text="@string/question_title"
            android:textSize="36sp" />

        <TextView
            style="@style/IChingBodyText"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="28dp"
            android:gravity="center"
            android:text="@string/question_body"
            android:textSize="18sp" />

        <LinearLayout style="@style/IChingCard">

            <EditText
                android:id="@id/question_input"
                style="@style/IChingInput"
                android:layout_height="170dp"
                android:hint="@string/question_hint"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLength="120"
                android:minLines="5"
                tools:text="我目前在工作上最需要調整的是什麼？" />

            <TextView
                android:id="@id/question_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="0 / 120"
                android:textColor="@color/ic_text_muted"
                android:textSize="12sp"
                tools:text="18 / 120" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="10dp"
            android:gravity="center"
            android:text="@string/question_presets_label"
            android:textColor="@color/ic_text_muted"
            android:textSize="14sp"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@id/question_presets"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                app:singleLine="true">

                <com.google.android.material.chip.Chip
                    style="@style/IChingFilterChip"
                    android:text="職涯" />

                <com.google.android.material.chip.Chip
                    style="@style/IChingFilterChip"
                    android:text="感情" />

                <com.google.android.material.chip.Chip
                    style="@style/IChingFilterChip"
                    android:text="人際" />

                <com.google.android.material.chip.Chip
                    style="@style/IChingFilterChip"
                    android:text="財務" />

                <com.google.android.material.chip.Chip
                    style="@style/IChingFilterChip"
                    android:text="學業" />

                <com.google.android.material.chip.Chip
                    style="@style/IChingFilterChip"
                    android:text="家庭" />

                <com.google.android.material.chip.Chip
                    style="@style/IChingFilterChip"
                    android:text="健康" />

                <com.google.android.material.chip.Chip
                    style="@style/IChingFilterChip"
                    android:text="決策" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <TextView
            android:id="@id/question_next_button"
            style="@style/IChingPrimaryButton"
            android:layout_marginTop="36dp"
            android:drawableEnd="@drawable/ic_arrow_forward_24"
            android:drawablePadding="8dp"
            android:drawableTint="@color/ic_background"
            android:text="@string/question_next" />
    </LinearLayout>
</ScrollView>
