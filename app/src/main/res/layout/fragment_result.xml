<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page"
    android:fillViewport="true"
    tools:context=".ui.ResultFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:id="@id/result_question_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:background="@drawable/bg_question_pill"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="10dp"
            android:paddingEnd="18dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@id/result_question_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/ic_text_muted"
                android:textSize="16sp"
                android:textStyle="italic"
                tools:text="“我目前在工作上最需要調整的是什麼？”" />
        </LinearLayout>

        <LinearLayout
            android:id="@id/result_hero_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_result_hero"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="24dp"
            android:paddingEnd="18dp"
            android:paddingBottom="24dp">

            <fcu.app.i_ching.ui.HexagramView
                android:id="@id/result_hexagram"
                android:layout_width="96dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:id="@id/result_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="4dp"
                android:fontFamily="@font/noto_serif_cjk_tc_regular"
                android:gravity="center"
                android:textColor="@color/ic_ink"
                android:textSize="36sp"
                android:textStyle="bold"
                tools:text="第15卦｜地山謙" />

            <TextView
                android:id="@id/result_tags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/ic_text_muted"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="謙虛 退讓 平衡" />

            <TextView
                android:id="@id/result_insight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/noto_serif_cjk_tc_regular"
                android:gravity="center"
                android:textColor="@color/ic_gold"
                android:textSize="22sp"
                tools:text="現在不是急著證明自己的時候，而是先降低姿態、補足資訊。" />
        </LinearLayout>

        <LinearLayout style="@style/ResultCard">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/noto_serif_cjk_tc_regular"
                android:text="本卦與之卦"
                android:textColor="@color/ic_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@id/result_relation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ic_gold"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="本卦：第15卦 地山謙｜之卦：第46卦 地風升" />

            <TextView
                android:id="@id/result_changing_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/ic_text_muted"
                android:textSize="15sp"
                tools:text="變爻：初六、六二。先收束姿態，再順勢推進。" />

            <TextView
                android:id="@id/result_changed_lines"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/ic_text_muted"
                android:textSize="15sp"
                android:visibility="gone"
                tools:text="初六：謙謙君子，用涉大川，吉。"
                tools:visibility="visible" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="vertical">

            <LinearLayout
                style="@style/IChingSectionCard"
                android:layout_width="match_parent">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="適合做"
                    android:textColor="@color/ic_gold"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@id/result_do_items"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/ic_text_muted"
                    android:textSize="15sp"
                    tools:text="先聽完對方需求&#10;拆解小步驟&#10;保留彈性" />
            </LinearLayout>

            <LinearLayout
                style="@style/IChingSectionCard"
                android:layout_width="match_parent"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="暫時避免"
                    android:textColor="@color/ic_error"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@id/result_avoid_items"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/ic_text_muted"
                    android:textSize="15sp"
                    tools:text="情緒化決定&#10;承諾過多" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            style="@style/ResultCard"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="盲點提醒"
                android:textColor="@color/ic_ink"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@id/result_blind_spot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/ic_text_muted"
                android:textSize="16sp"
                tools:text="你可能低估了沉默訊號，先確認彼此真正擔心的事。" />
        </LinearLayout>

        <LinearLayout
            android:id="@id/result_classical_card"
            style="@style/ResultCard"
            android:clickable="true"
            android:contentDescription="古典卦象解釋"
            android:focusable="true"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@id/result_classical_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/noto_serif_cjk_tc_regular"
                android:text="古典卦象解釋"
                android:textColor="@color/ic_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@id/result_classical_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ic_text_muted"
                android:textSize="16sp"
                tools:text="謙：亨，君子有終。&#10;&#10;天道虧盈而益謙，地道變盈而流謙。" />
        </LinearLayout>

        <LinearLayout
            style="@style/ResultCard"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/noto_serif_cjk_tc_regular"
                android:text="可分享文字"
                android:textColor="@color/ic_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@id/result_share_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ic_text_muted"
                android:textSize="15sp"
                tools:text="我問：工作上最需要調整的是什麼？&#10;得到：第15卦 地山謙。" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp"
            android:labelFor="@id/result_note_input"
            android:text="@string/result_note_label"
            android:textColor="@color/ic_ink"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@id/result_note_input"
            style="@style/IChingInput"
            android:layout_height="96dp"
            android:hint="@string/result_note_hint"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="3"
            tools:text="先把會議需求釐清，再回覆承諾。" />

        <TextView
            android:id="@id/result_save_button"
            style="@style/IChingPrimaryButton"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="10dp"
            android:contentDescription="儲存占卜結果筆記至紀錄"
            android:drawableStart="@drawable/ic_check_24"
            android:drawablePadding="8dp"
            android:drawableTint="@color/ic_background"
            android:text="@string/result_save_new" />

        <TextView
            android:id="@id/result_share_button"
            style="@style/IChingSecondaryButton"
            android:drawableStart="@drawable/ic_arrow_forward_24"
            android:drawablePadding="8dp"
            android:drawableTint="@color/ic_ink"
            android:text="@string/result_share" />
    </LinearLayout>
</ScrollView>
