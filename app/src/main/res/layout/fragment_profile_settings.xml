<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:gravity="center"
        android:text="我的"
        android:textColor="@color/ic_ink"
        android:textSize="38sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="管理本機模式、外觀與資料控制"
        android:textColor="@color/ic_text_muted"
        android:textSize="16sp" />

    <TextView
        style="@style/ProfileGroupTitle"
        android:text="個人資訊" />

    <LinearLayout
        android:id="@id/profile_info_group"
        style="@style/ProfileSettingsCard" />

    <TextView
        style="@style/ProfileGroupTitle"
        android:text="外觀" />

    <LinearLayout
        android:id="@id/profile_appearance_group"
        style="@style/ProfileSettingsCard" />

    <TextView
        style="@style/ProfileGroupTitle"
        android:text="占卜偏好" />

    <LinearLayout
        android:id="@id/profile_divination_group"
        style="@style/ProfileSettingsCard" />

    <TextView
        style="@style/ProfileGroupTitle"
        android:text="資料控制" />

    <LinearLayout
        android:id="@id/profile_data_group"
        style="@style/ProfileSettingsCard" />
</LinearLayout>
