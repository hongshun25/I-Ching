<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ic_background"
    android:orientation="vertical"
    tools:context=".ui.ProfileSettingsFragment">

    <include
        android:id="@id/top_bar"
        layout="@layout/include_top_bar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:typeface="serif"
                android:gravity="center"
                android:text="我的"
                android:textColor="@color/ic_ink"
                android:textSize="38sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="管理本機模式、外觀與資料控制"
                android:textColor="@color/ic_text_muted"
                android:textSize="16sp" />

            <TextView
                style="@style/ProfileGroupTitle"
                android:text="個人資訊" />

            <LinearLayout
                android:id="@id/profile_info_group"
                style="@style/ProfileSettingsCard">

                <LinearLayout style="@style/SettingsRow">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="使用模式" />

                    <TextView
                        style="@style/SettingsRowValue"
                        android:text="本機模式 ›" />
                </LinearLayout>

                <LinearLayout style="@style/SettingsRow">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="帳號同步" />

                    <TextView
                        style="@style/SettingsRowValue"
                        android:text="未啟用 ›" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/ProfileGroupTitle"
                android:text="外觀" />

            <LinearLayout
                android:id="@id/profile_appearance_group"
                style="@style/ProfileSettingsCard">

                <LinearLayout style="@style/SettingsRow">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="深色模式" />

                    <Switch
                        android:id="@id/profile_dark_mode_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="深色模式"
                        android:minWidth="48dp"
                        android:minHeight="48dp" />
                </LinearLayout>

                <LinearLayout style="@style/SettingsRow">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="字體大小" />

                    <TextView
                        style="@style/SettingsRowValue"
                        android:text="適中 ›" />
                </LinearLayout>

                <LinearLayout style="@style/SettingsRow">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="減少動態效果" />

                    <Switch
                        android:id="@id/profile_reduce_motion_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="減少動態效果"
                        android:minWidth="48dp"
                        android:minHeight="48dp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/ProfileGroupTitle"
                android:text="占卜偏好" />

            <LinearLayout
                android:id="@id/profile_divination_group"
                style="@style/ProfileSettingsCard">

                <LinearLayout style="@style/SettingsRow">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="預設占法" />

                    <TextView
                        style="@style/SettingsRowValue"
                        android:text="金錢卦 ›" />
                </LinearLayout>

                <LinearLayout style="@style/SettingsRow">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="自動儲存" />

                    <Switch
                        android:id="@id/profile_auto_save_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="自動儲存"
                        android:minWidth="48dp"
                        android:minHeight="48dp" />
                </LinearLayout>

                <LinearLayout style="@style/SettingsRow">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="提醒通知" />

                    <TextView
                        style="@style/SettingsRowValue"
                        android:text="未啟用 ›" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/ProfileGroupTitle"
                android:text="資料控制" />

            <LinearLayout
                android:id="@id/profile_data_group"
                style="@style/ProfileSettingsCard">

                <LinearLayout
                    android:id="@id/profile_export_json"
                    style="@style/SettingsRow"
                    android:clickable="true"
                    android:contentDescription="匯出 JSON，完整本機紀錄"
                    android:focusable="true">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="匯出 JSON" />

                    <TextView
                        style="@style/SettingsRowValue"
                        android:text="完整本機紀錄 ›" />
                </LinearLayout>

                <LinearLayout
                    android:id="@id/profile_export_text"
                    style="@style/SettingsRow"
                    android:clickable="true"
                    android:contentDescription="匯出純文字，方便閱讀與備份"
                    android:focusable="true">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="匯出純文字" />

                    <TextView
                        style="@style/SettingsRowValue"
                        android:text="方便閱讀與備份 ›" />
                </LinearLayout>

                <LinearLayout
                    android:id="@id/profile_delete_all"
                    style="@style/SettingsRow"
                    android:clickable="true"
                    android:contentDescription="刪除全部紀錄，不可復原"
                    android:focusable="true">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="刪除全部紀錄" />

                    <TextView
                        style="@style/SettingsRowValue"
                        android:text="不可復原 ›" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <include
        android:id="@id/bottom_nav"
        layout="@layout/include_bottom_nav" />
</LinearLayout>
