<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page"
    android:orientation="vertical"
    tools:context=".ui.ProfileSettingsFragment">

    <include
        android:id="@id/top_bar"
        layout="@layout/include_top_bar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/noto_serif_cjk_tc_regular"
                android:gravity="center"
                android:text="我的"
                android:textColor="@color/ic_ink"
                android:textSize="38sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="管理本機模式、外觀與資料控制"
                android:textColor="@color/ic_text_muted"
                android:textSize="16sp" />

            <TextView
                style="@style/ProfileGroupTitle"
                android:text="個人資訊" />

            <LinearLayout
                android:id="@id/profile_info_group"
                style="@style/ProfileSettingsCard">

                <LinearLayout style="@style/SettingsRow">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="使用模式" />

                    <TextView
                        android:id="@id/profile_account_mode_value"
                        style="@style/SettingsRowValue"
                        android:text="本機模式" />
                </LinearLayout>

                <LinearLayout style="@style/SettingsRow">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="帳號" />

                    <TextView
                        android:id="@id/profile_account_email_value"
                        style="@style/SettingsRowValue"
                        android:text="未登入"
                        tools:text="user@example.com" />
                </LinearLayout>

                <LinearLayout
                    android:id="@id/profile_auth_entry"
                    style="@style/SettingsRow"
                    android:clickable="true"
                    android:contentDescription="登入或註冊本機帳號"
                    android:focusable="true">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="登入 / 註冊" />

                    <TextView
                        style="@style/SettingsRowValue"
                        android:text="切換到本機帳號" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="6dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right_24"
                        app:tint="@color/ic_text_subtle" />
                </LinearLayout>

                <LinearLayout
                    android:id="@id/profile_change_password"
                    style="@style/SettingsRow"
                    android:clickable="true"
                    android:contentDescription="更改本機帳號密碼"
                    android:focusable="true">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="更改密碼" />

                    <TextView
                        style="@style/SettingsRowValue"
                        android:text="本機帳號" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="6dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right_24"
                        app:tint="@color/ic_text_subtle" />
                </LinearLayout>

                <LinearLayout
                    android:id="@id/profile_logout"
                    style="@style/SettingsRow"
                    android:clickable="true"
                    android:contentDescription="登出本機帳號"
                    android:focusable="true">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="登出" />

                    <TextView
                        style="@style/SettingsRowValue"
                        android:text="回到本機模式" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="6dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right_24"
                        app:tint="@color/ic_text_subtle" />
                </LinearLayout>

                <LinearLayout
                    android:id="@id/profile_delete_account"
                    style="@style/SettingsRow"
                    android:clickable="true"
                    android:contentDescription="刪除本機帳號"
                    android:focusable="true">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="刪除帳號" />

                    <TextView
                        style="@style/SettingsRowValue"
                        android:text="含此帳號資料" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="6dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right_24"
                        app:tint="@color/ic_text_subtle" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/ProfileGroupTitle"
                android:text="外觀" />

            <LinearLayout
                android:id="@id/profile_appearance_group"
                style="@style/ProfileSettingsCard">

                <LinearLayout style="@style/SettingsRow">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="深色模式" />

                    <Switch
                        android:id="@id/profile_dark_mode_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="深色模式"
                        android:minWidth="48dp"
                        android:minHeight="48dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@id/profile_font_size"
                    style="@style/SettingsRow"
                    android:clickable="true"
                    android:contentDescription="調整字體大小"
                    android:focusable="true">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="字體大小" />

                    <TextView
                        android:id="@id/profile_font_size_value"
                        style="@style/SettingsRowValue"
                        android:text="適中" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="6dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right_24"
                        app:tint="@color/ic_text_subtle" />
                </LinearLayout>

                <LinearLayout style="@style/SettingsRow">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="減少動態效果" />

                    <Switch
                        android:id="@id/profile_reduce_motion_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="減少動態效果"
                        android:minWidth="48dp"
                        android:minHeight="48dp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/ProfileGroupTitle"
                android:text="占卜偏好" />

            <LinearLayout
                android:id="@id/profile_divination_group"
                style="@style/ProfileSettingsCard">

                <LinearLayout
                    android:id="@id/profile_default_method"
                    style="@style/SettingsRow"
                    android:clickable="true"
                    android:contentDescription="選擇預設占法"
                    android:focusable="true">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="預設占法" />

                    <TextView
                        android:id="@id/profile_default_method_value"
                        style="@style/SettingsRowValue"
                        android:text="三枚銅錢" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="6dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right_24"
                        app:tint="@color/ic_text_subtle" />
                </LinearLayout>

                <LinearLayout style="@style/SettingsRow">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="自動儲存" />

                    <Switch
                        android:id="@id/profile_auto_save_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="自動儲存"
                        android:minWidth="48dp"
                        android:minHeight="48dp" />
                </LinearLayout>

                <LinearLayout style="@style/SettingsRow">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="每日提醒" />

                    <Switch
                        android:id="@id/profile_reminder_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="每日提醒"
                        android:minWidth="48dp"
                        android:minHeight="48dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@id/profile_reminder_time"
                    style="@style/SettingsRow"
                    android:clickable="true"
                    android:contentDescription="調整每日提醒時間"
                    android:focusable="true">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="提醒時間" />

                    <TextView
                        android:id="@id/profile_reminder_time_value"
                        style="@style/SettingsRowValue"
                        android:text="09:00" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="6dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right_24"
                        app:tint="@color/ic_text_subtle" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/ProfileGroupTitle"
                android:text="資料控制" />

            <LinearLayout
                android:id="@id/profile_data_group"
                style="@style/ProfileSettingsCard">

                <LinearLayout
                    android:id="@id/profile_export_json"
                    style="@style/SettingsRow"
                    android:clickable="true"
                    android:contentDescription="匯出 JSON，完整本機紀錄"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_file_download_24"
                        app:tint="@color/ic_text_subtle" />

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="匯出 JSON" />

                    <TextView
                        style="@style/SettingsRowValue"
                        android:text="完整本機紀錄" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="6dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right_24"
                        app:tint="@color/ic_text_subtle" />
                </LinearLayout>

                <LinearLayout
                    android:id="@id/profile_export_text"
                    style="@style/SettingsRow"
                    android:clickable="true"
                    android:contentDescription="匯出純文字，方便閱讀與備份"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_file_download_24"
                        app:tint="@color/ic_text_subtle" />

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="匯出純文字" />

                    <TextView
                        style="@style/SettingsRowValue"
                        android:text="方便閱讀與備份" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="6dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right_24"
                        app:tint="@color/ic_text_subtle" />
                </LinearLayout>

                <LinearLayout
                    android:id="@id/profile_delete_all"
                    style="@style/SettingsRow"
                    android:clickable="true"
                    android:contentDescription="刪除全部紀錄，不可復原"
                    android:focusable="true">

                    <TextView
                        style="@style/SettingsRowLabel"
                        android:text="刪除全部紀錄" />

                    <TextView
                        style="@style/SettingsRowValue"
                        android:text="不可復原" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="6dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right_24"
                        app:tint="@color/ic_text_subtle" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <include
        android:id="@id/bottom_nav"
        layout="@layout/include_bottom_nav" />
</LinearLayout>
