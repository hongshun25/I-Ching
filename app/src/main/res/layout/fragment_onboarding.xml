<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page"
    tools:context=".ui.OnboardingFragment">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@id/onboarding_recycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        tools:itemCount="1"
        tools:listitem="@layout/item_onboarding_page" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/ic_background"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="32dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:id="@id/onboarding_indicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:id="@id/onboarding_dot_daily"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_onboarding_indicator_dot" />

            <View
                android:id="@id/onboarding_dot_question"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_onboarding_indicator_dot" />

            <View
                android:id="@id/onboarding_dot_records"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_onboarding_indicator_dot" />
        </LinearLayout>

        <TextView
            android:id="@id/onboarding_start_button"
            style="@style/IChingPrimaryButton"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:text="@string/onboarding_start" />

        <TextView
            android:id="@id/local_mode_button"
            style="@style/IChingSecondaryButton"
            android:text="@string/onboarding_local_mode" />
    </LinearLayout>
</FrameLayout>
