<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="22dp">

    <TextView
        android:id="@id/record_item_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:textColor="@color/ic_ink"
        android:textSize="22sp" />

    <TextView
        android:id="@id/record_item_relation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/ic_gold"
        android:textStyle="bold"
        android:textSize="15sp" />

    <TextView
        android:id="@id/record_item_changing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/ic_outline_strong"
        android:textSize="13sp" />

    <TextView
        android:id="@id/record_item_question"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/ic_text_muted"
        android:textSize="16sp" />

    <TextView
        android:id="@id/record_item_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/ic_outline_strong"
        android:textSize="12sp" />

    <TextView
        android:id="@id/record_item_note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/ic_gold"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <Button
            android:id="@id/record_item_edit"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/record_edit_note" />

        <Button
            android:id="@id/record_item_delete"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="@string/record_delete" />
    </LinearLayout>
</LinearLayout>
