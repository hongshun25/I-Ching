<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:padding="16dp"
    tools:showIn="@layout/fragment_records">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <fcu.app.i_ching.ui.HexagramView
            android:id="@id/record_item_hexagram"
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="14dp" />

        <TextView
            android:id="@id/record_item_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/noto_serif_tc_family"
            android:textColor="@color/ic_ink"
            android:textSize="22sp"
            tools:text="第十五卦｜地山謙" />
    </LinearLayout>

    <TextView
        android:id="@id/record_item_question"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/ic_text_muted"
        android:textSize="16sp"
        tools:text="我目前在工作上最需要調整的是什麼？" />

    <TextView
        android:id="@id/record_item_relation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/ic_gold"
        android:textStyle="bold"
        android:textSize="15sp"
        tools:text="之卦：第46卦 地風升" />

    <TextView
        android:id="@id/record_item_changing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/ic_outline_strong"
        android:textSize="13sp"
        tools:text="變爻：初六、六二" />

    <TextView
        android:id="@id/record_item_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/ic_outline_strong"
        android:textSize="12sp"
        tools:text="三枚銅錢 · 2026/06/16" />

    <TextView
        android:id="@id/record_item_note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/ic_gold"
        android:textSize="15sp"
        android:visibility="gone"
        tools:text="筆記：先聽完需求，再回覆承諾。"
        tools:visibility="visible" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@id/record_item_edit"
            style="@style/IChingSecondaryButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/record_edit_note" />

        <com.google.android.material.button.MaterialButton
            android:id="@id/record_item_delete"
            style="@style/IChingSecondaryButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="@string/record_delete" />
    </LinearLayout>
</LinearLayout>
