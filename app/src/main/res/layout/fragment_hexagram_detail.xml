<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ic_background"
    android:orientation="vertical">

    <include
        android:id="@id/hex_detail_top_bar"
        layout="@layout/include_top_bar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <fcu.app.i_ching.ui.HexagramView
                android:id="@id/hex_detail_hexagram"
                android:layout_width="130dp"
                android:layout_height="wrap_content" />

            <LinearLayout
                android:id="@id/hex_detail_chips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:orientation="horizontal" />

            <TextView
                android:id="@id/hex_detail_title"
                style="@style/IChingPageTitle"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:textSize="40sp"
                android:textStyle="bold" />

            <TextView
                android:id="@id/hex_detail_summary"
                style="@style/IChingBodyText"
                android:gravity="center"
                android:textSize="18sp" />

            <LinearLayout
                android:id="@id/hex_detail_sections"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
