<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page"
    android:fillViewport="true"
    tools:context=".ui.MethodFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/method_step"
            android:textColor="@color/ic_text_muted"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            style="@style/IChingPageTitle"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:text="@string/method_title"
            android:textSize="34sp" />

        <TextView
            style="@style/IChingBodyText"
            android:gravity="center"
            android:text="@string/method_body" />

        <LinearLayout
            android:id="@id/method_simple_card"
            style="@style/IChingCard"
            android:layout_marginTop="30dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@id/method_simple_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_simple_hexagram_24" />

                <TextView
                    android:id="@id/method_simple_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/noto_serif_cjk_tc_regular"
                    android:text="簡易占法"
                    android:textColor="@color/ic_ink"
                    android:textSize="24sp" />

                <TextView
                    android:id="@id/method_simple_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/ic_check_24"
                    android:drawablePadding="4dp"
                    android:text="@string/method_selected"
                    android:textColor="@color/ic_gold"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@id/method_simple_detail"
                style="@style/IChingBodyText"
                android:layout_marginTop="6dp"
                android:text="適合快速反思，直接得出一卦，無變爻。" />
        </LinearLayout>

        <LinearLayout
            android:id="@id/method_coins_card"
            style="@style/IChingCard"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_selected"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@id/method_coins_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_coins_24" />

                <TextView
                    android:id="@id/method_coins_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/noto_serif_cjk_tc_regular"
                    android:text="三枚銅錢"
                    android:textColor="@color/ic_ink"
                    android:textSize="24sp" />

                <TextView
                    android:id="@id/method_coins_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/ic_check_24"
                    android:drawablePadding="4dp"
                    android:text="@string/method_selected"
                    android:textColor="@color/ic_gold"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="visible" />
            </LinearLayout>

            <TextView
                android:id="@id/method_coins_detail"
                style="@style/IChingBodyText"
                android:layout_marginTop="6dp"
                android:text="模擬傳統銅錢占法，六次投擲，可產生變爻，體現事物變動之機。" />
        </LinearLayout>

        <LinearLayout
            android:id="@id/method_yarrow_card"
            style="@style/IChingCard"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@id/method_yarrow_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_yarrow_24" />

                <TextView
                    android:id="@id/method_yarrow_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/noto_serif_cjk_tc_regular"
                    android:text="蓍草靈感模式"
                    android:textColor="@color/ic_ink"
                    android:textSize="24sp" />

                <TextView
                    android:id="@id/method_yarrow_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/ic_check_24"
                    android:drawablePadding="4dp"
                    android:text="@string/method_selected"
                    android:textColor="@color/ic_gold"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@id/method_yarrow_detail"
                style="@style/IChingBodyText"
                android:layout_marginTop="6dp"
                android:text="節奏較慢，十八變而成卦。適合重大決策前的深度提問與冥想沉澱。" />
        </LinearLayout>

        <TextView
            android:id="@id/method_next_button"
            style="@style/IChingPrimaryButton"
            android:layout_marginTop="10dp"
            android:drawableEnd="@drawable/ic_arrow_forward_24"
            android:drawablePadding="8dp"
            android:drawableTint="@color/ic_background"
            android:text="@string/method_next" />
    </LinearLayout>
</ScrollView>
