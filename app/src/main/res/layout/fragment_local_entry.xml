<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page"
    android:fillViewport="true"
    tools:context=".ui.LocalEntryFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="72dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/noto_serif_tc_family"
            android:gravity="center"
            android:text="@string/brand_title"
            android:textColor="@color/ic_ink"
            android:textSize="38sp"
            android:textStyle="bold" />

        <TextView
            style="@style/IChingBodyText"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="36dp"
            android:gravity="center"
            android:text="@string/splash_tagline" />

        <LinearLayout
            style="@style/IChingCard"
            android:layout_marginBottom="28dp"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/noto_serif_tc_family"
                android:gravity="center"
                android:text="@string/local_entry_title"
                android:textColor="@color/ic_ink"
                android:textSize="28sp" />

            <TextView
                style="@style/IChingBodyText"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/local_entry_subtitle" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="22dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_cloud_off_24" />

            <TextView
                style="@style/IChingBodyText"
                android:layout_marginTop="18dp"
                android:text="@string/local_entry_body" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@id/local_mode_button"
            style="@style/IChingPrimaryButton"
            android:contentDescription="@string/local_entry_primary"
            android:text="@string/local_entry_primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@id/local_entry_daily_preview_button"
            style="@style/IChingSecondaryButton"
            android:layout_marginTop="12dp"
            android:text="@string/local_entry_daily_preview" />
    </LinearLayout>
</ScrollView>
