<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page"
    android:fillViewport="true"
    tools:context=".ui.LocalEntryFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="72dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <TextView
            style="@style/IChingPageTitle"
            android:gravity="center"
            android:text="@string/local_entry_title"
            android:textSize="40sp"
            android:textStyle="bold" />

        <TextView
            style="@style/IChingBodyText"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"
            android:gravity="center"
            android:text="@string/local_entry_subtitle" />

        <LinearLayout
            style="@style/IChingCard"
            android:layout_marginBottom="28dp">

            <TextView
                style="@style/IChingBodyText"
                android:text="@string/local_entry_body" />
        </LinearLayout>

        <TextView
            android:id="@id/local_mode_button"
            style="@style/IChingPrimaryButton"
            android:contentDescription="@string/local_entry_primary"
            android:text="@string/local_entry_primary" />

        <TextView
            android:id="@id/local_entry_daily_preview_button"
            style="@style/IChingSecondaryButton"
            android:layout_marginTop="12dp"
            android:text="@string/local_entry_daily_preview" />
    </LinearLayout>
</ScrollView>
