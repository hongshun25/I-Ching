<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.IChing" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:colorAccent">@color/ic_gold</item>
        <item name="android:fontFamily">@font/noto_sans_tc_family</item>
        <item name="android:navigationBarColor">@color/ic_surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@drawable/bg_page</item>
        <item name="colorPrimary">@color/ic_ink</item>
        <item name="colorSecondary">@color/ic_gold</item>
        <item name="colorSurface">@color/ic_surface</item>
        <item name="colorSurfaceVariant">@color/ic_surface_container</item>
        <item name="colorOnSurface">@color/ic_ink</item>
        <item name="colorOnSurfaceVariant">@color/ic_text_muted</item>
        <item name="colorOutline">@color/ic_outline</item>
        <item name="colorError">@color/ic_error</item>
        <item name="materialButtonStyle">@style/IChingPrimaryButton</item>
        <item name="fontFamily">@font/noto_sans_tc_family</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="Theme.IChing" parent="Base.Theme.IChing" />

    <style name="BottomNavItem">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingEnd">6dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="BottomNavIcon">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="BottomNavLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="RecordsFilterChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">@drawable/bg_chip</item>
        <item name="android:gravity">center</item>
        <item name="android:minWidth">48dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingTop">5dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingBottom">5dp</item>
        <item name="android:textColor">@color/ic_text_muted</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="IChingFilterChip" parent="Widget.Material3.Chip.Filter">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:minWidth">48dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipBackgroundColor">@color/chip_background_color</item>
        <item name="chipMinHeight">48dp</item>
        <item name="chipStrokeColor">@color/chip_stroke_color</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipSurfaceColor">@color/ic_surface_container_low</item>
        <item name="ensureMinTouchTargetSize">true</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.IChing.Chip</item>
        <item name="android:textColor">@color/chip_text_color</item>
    </style>

    <style name="ShapeAppearance.IChing.Chip" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerSize">50%</item>
    </style>

    <style name="TextAppearance.IChing.TopBarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/noto_serif_tc_family</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:textColor">@color/ic_ink</item>
        <item name="android:textSize">22sp</item>
        <item name="fontFamily">@font/noto_serif_tc_family</item>
    </style>

    <style name="TextAppearance.IChing.BottomNav" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/noto_sans_tc_family</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">@font/noto_sans_tc_family</item>
    </style>

    <style name="TextAppearance.IChing.Display" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:fontFamily">@font/noto_serif_tc_family</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:textColor">@color/ic_ink</item>
        <item name="android:textSize">40sp</item>
        <item name="fontFamily">@font/noto_serif_tc_family</item>
    </style>

    <style name="TextAppearance.IChing.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/noto_serif_tc_family</item>
        <item name="android:textColor">@color/ic_ink</item>
        <item name="android:letterSpacing">0</item>
        <item name="fontFamily">@font/noto_serif_tc_family</item>
    </style>

    <style name="TextAppearance.IChing.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/noto_serif_tc_family</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:textColor">@color/ic_ink</item>
        <item name="android:textSize">24sp</item>
        <item name="fontFamily">@font/noto_serif_tc_family</item>
    </style>

    <style name="TextAppearance.IChing.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/noto_sans_tc_family</item>
        <item name="android:lineSpacingExtra">4dp</item>
        <item name="android:textColor">@color/ic_ink</item>
        <item name="android:textSize">16sp</item>
        <item name="fontFamily">@font/noto_sans_tc_family</item>
    </style>

    <style name="TextAppearance.IChing.BodyMuted" parent="TextAppearance.IChing.Body">
        <item name="android:textColor">@color/ic_text_muted</item>
    </style>

    <style name="TextAppearance.IChing.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:fontFamily">@font/noto_sans_tc_family</item>
        <item name="android:textColor">@color/ic_text_muted</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">@font/noto_sans_tc_family</item>
    </style>

    <style name="TextAppearance.IChing.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:fontFamily">@font/noto_sans_tc_family</item>
        <item name="android:textColor">@color/ic_text_subtle</item>
        <item name="android:textSize">12sp</item>
        <item name="fontFamily">@font/noto_sans_tc_family</item>
    </style>

    <style name="IChingPageTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/noto_serif_tc_family</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:textColor">@color/ic_ink</item>
        <item name="android:textSize">36sp</item>
    </style>

    <style name="IChingBodyText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/noto_sans_tc_family</item>
        <item name="android:lineSpacingExtra">4dp</item>
        <item name="android:textColor">@color/ic_ink</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="IChingBodyText.Muted" parent="IChingBodyText">
        <item name="android:textColor">@color/ic_text_muted</item>
    </style>

    <style name="IChingCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">@dimen/card_padding</item>
    </style>

    <style name="IChingSectionCard" parent="IChingCard">
        <item name="android:padding">@dimen/section_padding</item>
    </style>

    <style name="IChingInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:background">@drawable/bg_input_underline</item>
        <item name="android:gravity">top|start</item>
        <item name="android:fontFamily">@font/noto_sans_tc_family</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:lineSpacingExtra">3dp</item>
        <item name="android:textColor">@color/ic_ink</item>
        <item name="android:textColorHint">@color/ic_outline_strong</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="IChingPrimaryButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/control_height</item>
        <item name="android:fontFamily">@font/noto_sans_tc_family</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/ic_background</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/ic_ink</item>
        <item name="cornerRadius">@dimen/corner_pill</item>
        <item name="elevation">0dp</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">8dp</item>
        <item name="iconTint">@color/ic_background</item>
        <item name="rippleColor">@color/ic_gold_container</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="IChingTertiaryButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/control_height</item>
        <item name="android:fontFamily">@font/noto_sans_tc_family</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/ic_text_muted</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="cornerRadius">@dimen/corner_pill</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">8dp</item>
        <item name="iconTint">@color/ic_text_muted</item>
    </style>

    <style name="IChingSecondaryButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/control_height</item>
        <item name="android:fontFamily">@font/noto_sans_tc_family</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/ic_ink</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/ic_background</item>
        <item name="cornerRadius">@dimen/corner_pill</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">8dp</item>
        <item name="iconTint">@color/ic_ink</item>
        <item name="strokeColor">@color/ic_outline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="ResultCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">@dimen/card_padding</item>
    </style>

    <style name="ProfileGroupTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">30dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:textColor">@color/ic_outline_strong</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ProfileSettingsCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:divider">@drawable/divider_settings</item>
        <item name="android:orientation">vertical</item>
        <item name="android:paddingStart">@dimen/card_padding</item>
        <item name="android:paddingEnd">@dimen/card_padding</item>
        <item name="android:showDividers">middle</item>
    </style>

    <style name="SettingsRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <style name="SettingsRowLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">@color/ic_ink</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="SettingsRowValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/ic_text_muted</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>
