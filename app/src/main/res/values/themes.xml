<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.IChing" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">@color/ic_gold</item>
        <item name="android:navigationBarColor">@color/ic_surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorPrimary">@color/ic_ink</item>
        <item name="colorSecondary">@color/ic_gold</item>
        <item name="colorSurface">@color/ic_surface</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="Theme.IChing" parent="Base.Theme.IChing" />

    <style name="BottomNavItem">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingEnd">6dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="BottomNavIcon">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="BottomNavLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="RecordsFilterChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">@drawable/bg_chip</item>
        <item name="android:gravity">center</item>
        <item name="android:minWidth">48dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingTop">5dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingBottom">5dp</item>
        <item name="android:textColor">@color/ic_text_muted</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="IChingPageTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">serif</item>
        <item name="android:textColor">@color/ic_ink</item>
        <item name="android:textSize">36sp</item>
    </style>

    <style name="IChingBodyText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/ic_text_muted</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="IChingCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">@dimen/card_padding</item>
    </style>

    <style name="IChingInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:background">@drawable/bg_input_underline</item>
        <item name="android:gravity">top|start</item>
        <item name="android:padding">8dp</item>
        <item name="android:textColor">@color/ic_ink</item>
        <item name="android:textColorHint">@color/ic_outline_strong</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="IChingPrimaryButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/control_height</item>
        <item name="android:background">@drawable/bg_pill_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/ic_background</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="IChingSecondaryButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/control_height</item>
        <item name="android:background">@drawable/bg_pill_secondary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/ic_ink</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ResultCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">22dp</item>
    </style>

    <style name="ProfileGroupTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">30dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:textColor">@color/ic_outline_strong</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ProfileSettingsCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">22dp</item>
    </style>
</resources>
