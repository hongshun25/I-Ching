<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Questions and notes can be sensitive, so records stay local in cloud backup. -->
        <exclude domain="sharedpref" path="i_ching_records.xml" />
    </cloud-backup>
    <device-transfer>
        <!-- Keep local settings and records eligible for direct device-to-device moves. -->
        <include domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
